{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "coverImage": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "clientLink": {
      "type": "string",
      "format": "uri"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "client": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "icon": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "coverImage",
    "tags",
    "date"
  ]
}