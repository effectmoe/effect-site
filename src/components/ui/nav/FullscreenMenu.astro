---
import { socialLinks, contactInfo } from '@/config/socialLinks.data';
import { navItems } from '@/config/navItems.data';
import { t } from '@/lib/utils';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
---

<div id="menu-overlay" class="bg-foreground/40 fixed inset-0 z-40 hidden backdrop-blur-sm" aria-hidden="true"></div>

<!-- MENU -->
<div
  id="fullscreen-menu"
  class="bg-background fixed top-0 right-0 left-0 z-50 p-0.5 shadow-2xl"
  role="dialog"
  aria-modal="true"
  aria-labelledby="menu-title"
  aria-hidden="true"
  style="transform: translateY(-100%); will-change: transform;"
>
  <div class="bg-background flex h-[70vh] min-h-[400px] flex-col overflow-hidden">
    <!-- HEADER -->
    <header class="flex shrink-0 items-center justify-between px-4 py-4">
      <h2 id="menu-title" class="text-xl font-medium">
        {t('company.name')}
      </h2>
      <button
        id="menu-close-btn"
        class="focus-visible:ring-accent cursor-pointer transition-transform duration-200 hover:scale-110 focus:outline-none focus-visible:ring-2"
        aria-label="Close menu"
      >
        <Icon name="plus" class="size-9 rotate-45" />
      </button>
    </header>

    <!-- NAVIGATION -->
    <nav
      class="divide-foreground/20 border-foreground/20 flex flex-1 flex-col divide-y-2 overflow-x-hidden overflow-y-auto border-y-2"
      aria-label="Main navigation"
    >
      {
        navItems.map((item, index) => (
          <div class="group relative flex flex-1 flex-col">
            <a
              href={item.href}
              data-nav-link
              class="hover:bg-primary-foreground focus-visible:bg-primary-foreground flex flex-1 items-center justify-between px-4 transition-colors duration-300 outline-none"
            >
              <div class="menu-item-content flex min-w-0 flex-1 items-center gap-3">
                <span class="text-3xl font-medium">{item.title}</span>
              </div>
              <span class="menu-item-content group-hover:text-muted-foreground shrink-0 text-lg transition-colors">
                {(index + 1).toString().padStart(2, '0')}
              </span>
            </a>
          </div>
        ))
      }
    </nav>

    <!-- FOOTER -->
    <footer class="menu-footer-item flex shrink-0 flex-col gap-4 p-4">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <a
          href={`mailto:${contactInfo.email}`}
          class="font-grotesk text-foreground hover:text-muted text-lg underline-offset-4 hover:underline"
        >
          {contactInfo.email}
        </a>
        <ul class="flex flex-wrap gap-3">
          {
            socialLinks.map((s) => (
              <li>
                <Button variant="primary" size="icon" href={s.href} target="_blank" rel="noopener noreferrer">
                  <Icon name={`socials/${s.icon}`} class="size-5" />
                </Button>
              </li>
            ))
          }
        </ul>
      </div>
    </footer>
  </div>
</div>

<script>
  import gsap from 'gsap';

  const menu = document.getElementById('fullscreen-menu') as HTMLElement;
  const overlay = document.getElementById('menu-overlay') as HTMLElement;
  const closeBtn = document.getElementById('menu-close-btn') as HTMLButtonElement;

  let isOpen = false;
  let triggerElement: HTMLElement | null = null;
  let activeTimeline: gsap.core.Timeline | null = null;

  const isMobile = () => window.innerWidth < 1024;
  const reduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Mark current page
  const currentPath = window.location.pathname;
  document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach((link) => {
    const href = link.getAttribute('href') ?? '';
    const isActive = href === currentPath || (href !== '/' && currentPath.startsWith(href));
    if (isActive) {
      link.classList.add('bg-primary-foreground');
      link.classList.remove('hover:bg-primary-foreground');
      link.setAttribute('aria-current', 'page');
    }
  });

  function openMenu() {
    // Block opening on desktop
    if (!isMobile()) return;
    if (isOpen) return;

    isOpen = true;
    triggerElement = document.activeElement as HTMLElement;

    const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
    document.body.style.overflow = 'hidden';
    if (scrollbarWidth > 0) document.body.style.paddingRight = `${scrollbarWidth}px`;

    menu.setAttribute('aria-hidden', 'false');
    menu.removeAttribute('inert');
    overlay.classList.remove('hidden');

    if (reduceMotion()) {
      gsap.set(menu, { y: '0%' });
      closeBtn.focus();
      return;
    }

    activeTimeline?.kill();
    gsap.set('.menu-item-content, .menu-footer-item', { opacity: 1, y: 0 });

    const tl = gsap.timeline({ onComplete: () => closeBtn.focus() });
    activeTimeline = tl;

    tl.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.25, ease: 'none' });
    tl.fromTo(menu, { y: '-100%' }, { y: '0%', duration: 0.35, ease: 'power3.out', clearProps: 'transform' }, '-=0.15');
    tl.fromTo(
      '.menu-item-content',
      { y: 15, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.25,
        stagger: 0.02,
        ease: 'power2.out',
        clearProps: 'transform,opacity',
      },
      '-=0.25',
    );
  }

  function closeMenu() {
    if (!isOpen) return;

    activeTimeline?.kill();
    triggerElement?.focus();

    const finish = () => {
      isOpen = false;
      overlay.classList.add('hidden');

      menu.setAttribute('aria-hidden', 'true');
      menu.setAttribute('inert', '');

      gsap.set(menu, { y: '-100%' });
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
      window.dispatchEvent(new CustomEvent('closeMenu'));
    };

    if (reduceMotion()) {
      finish();
      return;
    }

    const tl = gsap.timeline({ onComplete: finish });
    activeTimeline = tl;

    tl.to('.menu-item-content, .menu-footer-item', {
      opacity: 0,
      y: 20,
      duration: 0.2,
      stagger: 0.015,
      ease: 'power2.in',
    });
    tl.to(menu, { y: '-100%', duration: 0.3, ease: 'power3.in' }, '-=0.1');
    tl.to(overlay, { opacity: 0, duration: 0.25 }, '-=0.3');
  }

  // Close if resized to desktop while menu is open
  window.addEventListener('resize', () => {
    if (isOpen && !isMobile()) closeMenu();
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!isOpen) return;
    if (e.key === 'Escape') {
      e.preventDefault();
      closeMenu();
      return;
    }
    if (e.key === 'Tab') {
      const focusable = menu.querySelectorAll<HTMLElement>('a[href], button:not([disabled])');
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  closeBtn.addEventListener('click', closeMenu);
  overlay.addEventListener('click', closeMenu);
  document.querySelectorAll('[data-nav-link]').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
  window.addEventListener('toggleMenu', (e: Event) => {
    const custom = e as CustomEvent<{ isOpen: boolean }>;
    custom.detail.isOpen ? openMenu() : closeMenu();
  });
  document.addEventListener('astro:page-load', () => {
    if (isOpen) closeMenu();
  });
</script>
