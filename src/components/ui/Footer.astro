---
import { t } from '@/lib/utils';
import { Icon } from 'astro-icon/components';
import { navItems, footerOtherItems } from '@/config/navItems.data';
import { socialLinks, contactInfo } from '@/config/socialLinks.data';
---

<footer class="bg-primary text-primary-foreground overflow-hidden">
  <div class="container mx-auto px-4">
    <!-- Top massive CTA area -->
    <a
      href="/contact"
      class="border-primary-foreground/20 group flex cursor-pointer flex-col items-center justify-center gap-2 border border-y px-6 py-8 transition-colors duration-500 md:flex-row md:items-center md:justify-center md:gap-6 md:px-4 md:py-16"
    >
      <h2
        class="font-clash group-hover:text-accent w-full text-center text-[clamp(2.8rem,12vw,8rem)] leading-[0.9] transition-colors duration-500 md:w-auto md:text-left md:text-[clamp(2rem,8vw,8rem)] md:leading-none md:whitespace-nowrap"
      >
        {t('footer.cta')}
      </h2>
      <div
        class="text-primary-foreground group-hover:text-accent h-[clamp(2.2rem,10vw,6rem)] w-[clamp(2.2rem,10vw,6rem)] shrink-0 transition-colors duration-500 md:h-[clamp(3rem,8vw,6rem)] md:w-[clamp(3rem,8vw,6rem)]"
      >
        <Icon name="arrow" class="h-full w-full" />
      </div>
    </a>

    <!-- Bottom grid area -->
    <div class="border-primary-foreground/20 grid grid-cols-1 border-b lg:grid-cols-8">
      <!-- Area 1: Logo & Company Info -->
      <div
        class="border-primary-foreground/20 bg-accent flex min-h-[320px] flex-col justify-between border-b p-6 text-black md:min-h-[400px] md:border-b-0 lg:col-span-3 lg:min-h-[480px] lg:border-r lg:p-8"
      >
        <div class="relative mb-8 flex flex-1 flex-col md:mb-12">
          <div class="flex flex-1 items-center justify-center p-4">
            <Icon name="world" class="h-auto w-full max-w-[100px] opacity-90 md:max-w-[140px]" />
          </div>
          <div class="mt-auto mb-4 flex items-center justify-evenly pb-4">
            <Icon name="asterisk" class="h-4 w-4" />
            <Icon name="asterisk" class="h-4 w-4" />
            <Icon name="asterisk" class="h-4 w-4" />
          </div>
        </div>
        <div class="flex flex-col items-center text-center">
          <p class="leading-extra-tight max-w-[200px] text-xl font-medium md:text-2xl">
            {t('footer.bottombar.text')}
          </p>
        </div>
      </div>

      <!-- Area 2: Navigation Links -->
      <div class="border-primary-foreground/20 flex flex-col border-b md:border-b-0 lg:col-span-3 lg:border-r">
        <ul class="flex h-full flex-col text-lg font-medium md:text-xl">
          {
            navItems.map((item, i) => (
              <li
                class:list={[
                  'group hover:text-accent flex flex-1 cursor-pointer items-stretch transition-colors',
                  i < navItems.length && 'border-primary-foreground/20 border-b',
                ]}
              >
                <a href={item.href} class="flex flex-1 items-center justify-between px-6 py-4 md:px-8 lg:py-0">
                  {item.title}
                  <Icon
                    name="arrow"
                    class="h-4 w-4 shrink-0 stroke-current opacity-40 transition-opacity group-hover:opacity-100 md:h-5 md:w-5"
                  />
                </a>
              </li>
            ))
          }
          {
            footerOtherItems.map((item, i) => (
              <li
                class:list={[
                  'group hover:text-accent flex flex-1 cursor-pointer items-stretch transition-colors',
                  i < footerOtherItems.length - 1 && 'border-primary-foreground/20 border-b',
                ]}
              >
                <a href={item.href} class="flex flex-1 items-center justify-between px-6 py-4 md:px-8 lg:py-0">
                  {item.title}
                  <Icon
                    name="arrow"
                    class="h-4 w-4 shrink-0 stroke-current opacity-40 transition-opacity group-hover:opacity-100 md:h-5 md:w-5"
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Area 3: Socials & Contact -->
      <div
        class="border-primary-foreground/20 flex flex-col justify-between space-y-8 border-b p-6 md:border-b-0 lg:col-span-2 lg:border-r"
      >
        <div>
          <h3 class="font-clash text-accent mb-4 text-lg tracking-wider md:mb-6 xl:text-3xl">
            {t('footer.follow')}
          </h3>
          <ul class="flex flex-col space-y-3 text-base md:text-lg">
            {
              socialLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-accent transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Reach Out -->
        <div>
          <h3 class="font-clash text-accent mb-2 text-lg font-medium tracking-wider lg:text-2xl">
            {t('footer.contact')}
          </h3>
          <a
            href={`mailto:${contactInfo.email}`}
            class="font-clash hover:text-accent text-lg tracking-wider break-all transition-colors xl:text-2xl"
          >
            {contactInfo.email}
          </a>
        </div>

        <div>
          <p class="text-xs tracking-widest uppercase">{t('footer.bottombar')}</p>
        </div>
      </div>
    </div>
  </div>
</footer>
