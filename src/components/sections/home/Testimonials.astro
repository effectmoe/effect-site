---
import { testimonials, stats } from '@/config/testimonials.data';
import MarqueeText from '@/components/common/MarqueeText.astro';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/lib/utils';
---

<section class="py-20 lg:py-28 space-y-6 md:space-y-12">
  <!-- Header -->
  <div class="container mx-auto flex flex-col gap-6 px-4 md:flex-row md:items-end md:justify-between">
    <div class="space-y-3 md:space-y-5">
      <MarqueeText text={t('index.testimonials.marqueetext')} />
      <h2 class="font-clash text-4xl md:text-7xl max-w-4xl">
        {t('index.testimonials.title')}
      </h2>
    </div>

    <!-- Navigation -->
    <div class="flex items-center gap-2">
      <Button variant="primary" class="testi-prev p-4" aria-label="Previous testimonial">
        <Icon name="arrow" class='-rotate-135'/>
      </Button>

      <Button variant="primary" class="testi-next p-4" aria-label="Next testimonial">
        <Icon name="arrow" class='rotate-45'/>
      </Button>
    </div>
  </div>

  <!-- Carousel -->
  <div
    class="testi-carousel relative flex snap-x snap-mandatory gap-6 overflow-x-auto px-[6vw] md:px-[10.4vw] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
  >
    {
      testimonials.map((testimonial) => (
        <div class="bg-muted-foreground/30 relative w-[85vw] shrink-0 snap-center p-0.5 md:w-[60vw] lg:w-[650px]">
          <div class="bg-primary-foreground flex h-full w-full flex-col justify-between p-6">

            <!-- Content -->
            <div class="flex flex-col gap-8 max-w-[720px]">
              <h3 class="text-3xl font-bold">
                {testimonial.company}
              </h3>

              <div class="flex flex-col gap-3">
                <svg class="text-accent w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M11.192 15.757c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.956.76-3.022.66-1.065 1.515-1.867 2.558-2.403L9.373 5c-.8.396-1.56.898-2.26 1.505-.71.607-1.34 1.305-1.9 2.094s-.98 1.68-1.25 2.69-.346 2.04-.217 3.1c.168 1.4.62 2.52 1.356 3.35.735.84 1.652 1.26 2.748 1.26.965 0 1.766-.29 2.4-.878.628-.576.94-1.365.94-2.368zm9.124 0c0-.88-.23-1.618-.69-2.217-.326-.42-.77-.692-1.327-.817-.56-.124-1.074-.13-1.54-.022-.16-.94.09-1.95.75-3.02.66-1.06 1.514-1.86 2.557-2.4L18.49 5c-.8.396-1.555.898-2.26 1.505-.708.607-1.34 1.305-1.894 2.094-.556.79-.98 1.68-1.25 2.69-.267 1.01-.345 2.04-.217 3.1.168 1.4.62 2.52 1.356 3.35.735.84 1.652 1.26 2.748 1.26.965 0 1.766-.29 2.4-.878.628-.576.94-1.365.94-2.368z"/>
                </svg>

                <p class="font-grotesk text-primary text-lg leading-relaxed md:text-xl">
                  {testimonial.quote}
                </p>
              </div>
            </div>

            <!-- Author -->
            <div class="mt-10">
              <p class="font-mono text-primary text-base font-medium">
                {testimonial.author}
              </p>
              <p class="text-muted mt-1 font-mono text-[10px] tracking-widest uppercase md:text-xs">
                {testimonial.role} OF {testimonial.company}
              </p>
            </div>

          </div>
        </div>
      ))
    }
  </div>

  <!-- Stats -->
  <div class="container mx-auto px-4">
  <div class="bg-muted-foreground/30 grid grid-cols-2 gap-0.5 p-0.5 lg:grid-cols-4">
    {
      stats.map((stat) => (
        <div class="bg-primary-foreground group flex items-center justify-center gap-3 p-6 lg:justify-start lg:p-10">
          <span class="font-grotesk font-bold text-5xl">
            {stat.num}
          </span>
          <div class="flex flex-col">
            <span class="font-grotesk text-accent font-bold text-xl md:text-2xl">
              {stat.suffix}
            </span>
            <span class="text-muted font-mono text-xs md:text-sm font-normal">
              {stat.label}
            </span>
          </div>
        </div>
      ))
    }
  </div>
</div>
</section>

<script>
  const initCarousel = () => {
    const carousel = document.querySelector<HTMLElement>('.testi-carousel');
    const nextBtn = document.querySelector<HTMLButtonElement>('.testi-next');
    const prevBtn = document.querySelector<HTMLButtonElement>('.testi-prev');
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>('.testi-carousel > div')
    );

    if (!carousel || !nextBtn || !prevBtn || cards.length === 0) return;

    let currentIndex: number = 0;

    const centerCard = (index: number): void => {
      const card = cards[index];
      if (!card) return;

      const carouselRect = carousel.getBoundingClientRect();
      const cardRect = card.getBoundingClientRect();

      const offset =
        card.offsetLeft -
        (carouselRect.width / 2 - cardRect.width / 2);

      carousel.scrollTo({
        left: offset,
        behavior: 'smooth',
      });
    };

    const goTo = (index: number): void => {
      const clampedIndex = Math.max(0, Math.min(index, cards.length - 1));
      currentIndex = clampedIndex;
      centerCard(clampedIndex);
    };

    const handleNext = (): void => goTo(currentIndex + 1);
    const handlePrev = (): void => goTo(currentIndex - 1);

    nextBtn.addEventListener('click', handleNext);
    prevBtn.addEventListener('click', handlePrev);

    requestAnimationFrame(() => centerCard(0));

    let scrollTimeout: number | undefined;

    const handleScroll = (): void => {
      if (scrollTimeout) window.clearTimeout(scrollTimeout);

      scrollTimeout = window.setTimeout(() => {
        let closestIndex = 0;
        let minDistance = Infinity;

        const containerCenter = carousel.getBoundingClientRect().left + carousel.offsetWidth / 2;

        cards.forEach((card, i) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.left + rect.width / 2;

          const distance = Math.abs(cardCenter - containerCenter);

          if (distance < minDistance) {
            minDistance = distance;
            closestIndex = i;
          }
        });

        currentIndex = closestIndex;
      }, 100);
    };

    carousel.addEventListener('scroll', handleScroll);

    return () => {
      nextBtn.removeEventListener('click', handleNext);
      prevBtn.removeEventListener('click', handlePrev);
      carousel.removeEventListener('scroll', handleScroll);
    };
  };

  initCarousel();
</script>
