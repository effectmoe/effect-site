---
---
<div id="ai-chat" class="flex flex-col">
  <!-- Label -->
  <div class="mb-4 flex items-center gap-3 lg:mb-6">
    <span class="font-mono text-[10px] tracking-[0.18em] text-black/40 uppercase">Ask Effect AI</span>
    <span id="ai-status" class="inline-block h-1.5 w-1.5 rounded-full bg-black/20"></span>
  </div>

  <!-- Conversation -->
  <div id="ai-messages" class="space-y-4 overflow-y-auto pr-1 lg:space-y-5" style="scrollbar-width: none;">
    <div class="ai-msg" data-role="assistant">
      <p class="font-mono text-xs leading-[1.8] text-black/40">
        LLMO・AIコンテンツ戦略・EFFECTのサービスについて<br class="hidden lg:block">
        何でもご質問ください。
      </p>
    </div>
  </div>

  <!-- Suggestions -->
  <div id="ai-suggestions" class="mt-3 flex flex-wrap gap-x-3 gap-y-1 lg:mt-4 lg:gap-x-4">
    <button class="ai-suggestion font-mono text-[10px] tracking-widest text-black/30 uppercase transition-colors hover:text-black">
      LLMOとは？
    </button>
    <button class="ai-suggestion font-mono text-[10px] tracking-widest text-black/30 uppercase transition-colors hover:text-black">
      EFFECTに依頼するには
    </button>
    <button class="ai-suggestion font-mono text-[10px] tracking-widest text-black/30 uppercase transition-colors hover:text-black">
      AIコンテンツ戦略
    </button>
  </div>

  <!-- Input -->
  <div class="mt-4 flex items-center gap-3 border-b border-black/20 pb-2 lg:mt-6">
    <input
      id="ai-input"
      type="text"
      placeholder="質問を入力..."
      maxlength="200"
      class="flex-1 bg-transparent font-mono text-xs text-black outline-none placeholder:text-black/25"
    />
    <button
      id="ai-send"
      aria-label="送信"
      class="font-mono text-xs text-black/30 transition-colors hover:text-black"
    >
      →
    </button>
  </div>
</div>

<style>
  /* Desktop: tall message area */
  @media (min-width: 1024px) {
    #ai-messages { max-height: 240px; }
    #ai-chat { border-bottom: 1px solid rgba(0,0,0,0.1); padding-bottom: 2.5rem; }
  }
  /* Mobile: compact — just enough for a couple messages */
  @media (max-width: 1023px) {
    #ai-messages { max-height: 72px; }
    #ai-chat { border-bottom: 1px solid rgba(0,0,0,0.08); padding-bottom: 1rem; margin-bottom: 1.25rem; }
  }

  .ai-msg[data-role="user"] p {
    color: rgba(0,0,0,0.75);
    text-align: right;
  }
  .ai-msg[data-role="user"] {
    display: flex;
    justify-content: flex-end;
  }

  .ai-msg[data-role="assistant"] p {
    color: rgba(0,0,0,0.45);
  }

  .typing::after {
    content: '▋';
    animation: blink 0.8s step-end infinite;
    opacity: 0.4;
  }
  @keyframes blink { 0%,100%{opacity:0.4} 50%{opacity:0} }

  #ai-messages::-webkit-scrollbar { display: none; }

  #ai-input::placeholder { color: rgba(0,0,0,0.25); }
  #ai-input.animating::placeholder { color: rgba(0,0,0,0.35); }
</style>

<script>
  const messagesEl = document.getElementById('ai-messages')!;
  const inputEl    = document.getElementById('ai-input') as HTMLInputElement;
  const sendBtn    = document.getElementById('ai-send')!;
  const statusDot  = document.getElementById('ai-status')!;
  const suggestEl  = document.getElementById('ai-suggestions')!;

  const history: { role: 'user'|'assistant'; content: string }[] = [];

  // ── Typewriter placeholder ────────────────────────────────
  const questions = [
    'LLMOとは何ですか？',
    'AIにコンテンツを引用させるには？',
    'EFFECTのサービスを教えてください',
    'SEOとLLMOの違いは？',
    'コンテンツ戦略の始め方',
    'AIがブランドを認識する仕組みは？',
  ];

  let qIdx = 0;
  let charIdx = 0;
  let deleting = false;
  let animFrame: ReturnType<typeof setTimeout>;
  let isUserFocused = false;

  function typeStep() {
    if (isUserFocused || inputEl.value) return;

    const q = questions[qIdx];

    if (!deleting) {
      charIdx++;
      inputEl.placeholder = q.slice(0, charIdx);
      if (charIdx === q.length) {
        deleting = true;
        animFrame = setTimeout(typeStep, 2200);
        return;
      }
      animFrame = setTimeout(typeStep, 65);
    } else {
      charIdx--;
      inputEl.placeholder = q.slice(0, charIdx);
      if (charIdx === 0) {
        deleting = false;
        qIdx = (qIdx + 1) % questions.length;
        animFrame = setTimeout(typeStep, 400);
        return;
      }
      animFrame = setTimeout(typeStep, 28);
    }
  }

  setTimeout(() => { inputEl.classList.add('animating'); typeStep(); }, 1200);

  inputEl.addEventListener('focus', () => {
    isUserFocused = true;
    clearTimeout(animFrame);
    inputEl.placeholder = '質問を入力...';
    inputEl.classList.remove('animating');
  });
  inputEl.addEventListener('blur', () => {
    if (!inputEl.value) {
      isUserFocused = false;
      charIdx = 0;
      deleting = false;
      setTimeout(() => { inputEl.classList.add('animating'); typeStep(); }, 800);
    }
  });
  // ─────────────────────────────────────────────────────────

  function addMsg(role: 'user'|'assistant', text = '') {
    const div = document.createElement('div');
    div.className = 'ai-msg';
    div.dataset.role = role;
    const p = document.createElement('p');
    p.className = 'font-mono text-xs leading-[1.8]';
    if (role === 'user') {
      const label = document.createElement('span');
      label.className = 'mb-1 block font-mono text-[10px] tracking-widest text-black/25 uppercase text-right';
      label.textContent = 'YOU';
      div.appendChild(label);
    }
    p.textContent = text;
    div.appendChild(p);
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return p;
  }

  function setLoading(loading: boolean) {
    statusDot.style.backgroundColor = loading ? '#000' : 'rgba(0,0,0,0.2)';
    inputEl.disabled = loading;
    sendBtn.toggleAttribute('disabled', loading);
  }

  async function send(text: string) {
    if (!text.trim() || inputEl.disabled) return;
    suggestEl.style.display = 'none';
    addMsg('user', text);
    history.push({ role: 'user', content: text });
    inputEl.value = '';
    setLoading(true);

    const p = addMsg('assistant');
    p.classList.add('typing');

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history: history.slice(-6) }),
      });
      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

      const reader = res.body.getReader();
      const dec = new TextDecoder();
      let full = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        for (const line of dec.decode(value, { stream: true }).split('\n')) {
          if (!line.startsWith('data: ')) continue;
          const raw = line.slice(6).trim();
          if (raw === '[DONE]') break;
          try {
            const d = JSON.parse(raw);
            const token = d.response ?? d.choices?.[0]?.delta?.content ?? '';
            full += token;
            p.textContent = full;
            messagesEl.scrollTop = messagesEl.scrollHeight;
          } catch {}
        }
      }
      history.push({ role: 'assistant', content: full });
    } catch {
      p.textContent = '接続エラー。しばらくしてから再試行してください。';
    } finally {
      p.classList.remove('typing');
      setLoading(false);
      inputEl.focus();
    }
  }

  sendBtn.addEventListener('click', () => send(inputEl.value));

  // ── IME（日本語入力）対応 ─────────────────────────────────
  let isComposing = false;
  inputEl.addEventListener('compositionstart', () => { isComposing = true; });
  inputEl.addEventListener('compositionend', () => { isComposing = false; });
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !isComposing) { e.preventDefault(); send(inputEl.value); }
  });
  // ─────────────────────────────────────────────────────────

  document.querySelectorAll<HTMLButtonElement>('.ai-suggestion').forEach((b) => {
    b.addEventListener('click', () => send(b.textContent!.trim()));
  });
</script>
