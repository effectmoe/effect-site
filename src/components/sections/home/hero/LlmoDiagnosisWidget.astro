---
---
<div id="hero-diagnosis" class="border-t border-black/10 pt-4 lg:pt-5">

  <!-- Label -->
  <span class="font-mono text-[11px] tracking-[0.22em] text-black/60 uppercase">LLMO 簡易診断</span>
  <p class="mt-0.5 font-mono text-xs text-black/55 leading-relaxed">
    AI検索への対応状況を部分的に無料診断します <span class="text-black/35">/ ページ単位</span>
  </p>

  <!-- URL Input row -->
  <div class="mt-3 flex gap-0">
    <input
      id="dw-url"
      type="url"
      placeholder="https://example.com/page"
      class="flex-1 min-w-0 border border-black/15 border-r-0 bg-transparent px-3 py-2 font-mono text-xs text-black outline-none placeholder:text-black/20 focus:border-black/40 transition-colors"
    />
    <button
      id="dw-run"
      class="bg-black px-4 py-2 font-mono text-[10px] tracking-[0.14em] text-white uppercase hover:bg-black/75 transition-colors whitespace-nowrap disabled:opacity-40"
    >
      診断
    </button>
  </div>

  <!-- Status / Error -->
  <p id="dw-status" class="hidden mt-2 font-mono text-[10px] text-black/35 animate-pulse">診断中...</p>
  <p id="dw-error"  class="hidden mt-2 font-mono text-[10px] text-red-600/70"></p>

  <!-- Results -->
  <div id="dw-result" class="hidden mt-4">

    <!-- Score -->
    <div class="flex items-start gap-2 pb-3 border-b border-black/8">
      <span id="dw-score" class="font-clash text-5xl leading-none">—</span>
      <div class="flex flex-col ml-1 gap-0.5 pt-1">
        <div class="flex items-baseline gap-1.5">
          <span class="font-mono text-xs text-black/30">/100</span>
          <span id="dw-grade" class="font-mono text-base font-bold"></span>
        </div>
        <span id="dw-grade-desc" class="font-mono text-[11px] text-black/50 leading-snug"></span>
      </div>
      <span id="dw-domain" class="font-mono text-[10px] text-black/35 ml-auto truncate max-w-[120px] pt-1"></span>
    </div>

    <!-- Check rows -->
    <ul id="dw-checks" class="mt-3"></ul>

    <!-- AI crawler note -->
    <div class="mt-4 border-l-2 border-black/10 pl-3">
      <p class="font-mono text-xs leading-relaxed text-black/55">
        この診断は GPTBot・PerplexityBot などの AIクローラーと同じ手法で、静的 HTML のみを解析しています。
      </p>
      <p class="mt-1.5 font-mono text-xs leading-relaxed text-black/45">
        JavaScript で描画されるメタタグや構造化データは AI にも認識されないため、このスコアに正直に反映されます。スコアが低い場合、あなたのサイトは Google には見えていても、AI には見えていない可能性があります。
      </p>
    </div>

    <!-- Email: send results -->
    <div class="mt-5 pt-4 border-t border-black/8">
      <div id="dw-email-trigger">
        <button id="dw-email-open" class="font-mono text-xs tracking-[0.1em] text-black/65 uppercase underline underline-offset-4 decoration-black/20 hover:text-black hover:decoration-black/60 transition-colors">
          診断結果を受け取る →
        </button>
      </div>
      <div id="dw-email-section" class="hidden">
        <div class="flex items-center gap-2 border-b border-black/15 pb-2">
          <input
            id="dw-email-input"
            type="email"
            placeholder="メールアドレスを入力..."
            class="flex-1 bg-transparent font-mono text-xs text-black outline-none placeholder:text-black/25"
          />
          <button id="dw-email-send" class="font-mono text-xs text-black/40 transition-colors hover:text-black">→</button>
        </div>
        <p id="dw-email-status" class="hidden mt-1.5 font-mono text-[10px] text-black/40"></p>
      </div>
    </div>

    <!-- Full report CTA -->
    <div class="mt-3">
      <a
        href="/contact"
        class="font-mono text-xs tracking-[0.1em] text-black/55 uppercase underline underline-offset-4 decoration-black/20 hover:text-black hover:decoration-black/60 transition-colors"
      >
        完全分析を依頼する →
      </a>
    </div>
  </div>
</div>

<script>
  const urlInput    = document.getElementById('dw-url')         as HTMLInputElement;
  const runBtn      = document.getElementById('dw-run')         as HTMLButtonElement;
  const statusEl    = document.getElementById('dw-status')!;
  const errorEl     = document.getElementById('dw-error')!;
  const resultEl    = document.getElementById('dw-result')!;
  const scoreEl     = document.getElementById('dw-score')!;
  const gradeEl     = document.getElementById('dw-grade')!;
  const gradeDescEl = document.getElementById('dw-grade-desc')!;
  const domainEl    = document.getElementById('dw-domain')!;
  const checksEl    = document.getElementById('dw-checks')!;
  const emailTrig   = document.getElementById('dw-email-trigger')!;
  const emailOpen   = document.getElementById('dw-email-open')!;
  const emailSec    = document.getElementById('dw-email-section')!;
  const emailInput  = document.getElementById('dw-email-input') as HTMLInputElement;
  const emailSend   = document.getElementById('dw-email-send')!;
  const emailStat   = document.getElementById('dw-email-status')!;

  const CHECK_LABELS: Record<string, string> = {
    llmsTxt:        'llms.txt',
    robotsTxt:      'robots.txt',
    sitemapXml:     'sitemap.xml',
    metaTags:       'メタタグ',
    structuredData: '構造化データ',
    topicCluster:   'コンテンツ構造',
  };

  const MAX_SCORES: Record<string, number> = {
    llmsTxt: 40, robotsTxt: 20, sitemapXml: 10, structuredData: 30, metaTags: 10, topicCluster: 20,
  };

  const GRADE_DESCS: Record<string, string> = {
    A: 'AI検索への対応が優秀です',
    B: '概ね良好。改善の余地があります',
    C: '基本的な対応が不足しています',
    D: '重要な設定が欠けています',
    F: 'AI検索への対応がほぼ未実施です',
  };

  let lastUrl = '';
  let lastResult: any = null;

  function getSymbol(key: string, c: any): { sym: string; color: string; scoreColor: string } {
    const G = { sym: '○', color: 'rgba(0,110,0,0.82)',    scoreColor: 'rgba(0,0,0,0.32)' };
    const W = { sym: '△', color: 'rgba(155,105,0,0.88)', scoreColor: 'rgba(155,105,0,0.75)' };
    const B = { sym: '×', color: 'rgba(176,36,36,0.88)',  scoreColor: 'rgba(176,36,36,0.72)' };
    switch (key) {
      case 'llmsTxt':
        if (!c.exists) return W;
        if (c.entryCount >= 5) return G;
        return W;
      case 'robotsTxt':
        if (!c.exists) return B;
        if (c.aiAllowed) return G;
        return (c.blockedBots?.length ?? 0) < 4 ? W : B;
      case 'sitemapXml':
        return c.exists ? G : B;
      case 'metaTags': {
        const n = [c.title, c.description, c.hasOgp].filter(Boolean).length;
        if (n === 3) return G;
        if (n > 0)  return W;
        return B;
      }
      case 'structuredData': {
        if (!c.schemasFound) return B;
        const hasErr = (c.schemas ?? []).some((s: any) => s.issues?.some((i: any) => i.sev === 'error'));
        return hasErr ? W : G;
      }
      case 'topicCluster':
        return c.score >= 16 ? G : c.score >= 8 ? W : B;
      default:
        return ('exists' in c ? c.exists : (c.schemasFound ?? c.score) > 0) ? G : B;
    }
  }

  function renderCheck(key: string, c: any) {
    const max = MAX_SCORES[key] ?? 10;
    const score = c.score ?? 0;
    const { sym, color: dotColor, scoreColor } = getSymbol(key, c);

    let detail = c.message;
    let sub = '';

    if (key === 'llmsTxt' && c.exists) {
      detail = `${c.entryCount}エントリ・${c.size}バイト検出`;
      if (c.preview) sub = `"${c.preview.slice(0, 55)}${c.preview.length > 55 ? '…' : ''}"`;
    }
    if (key === 'robotsTxt' && c.exists && !c.aiAllowed && c.blockedBots?.length) {
      sub = `ブロック中: ${c.blockedBots.join(', ')}`;
    }
    if (key === 'metaTags' && c.score > 0) {
      detail = `タイトル ${c.title ? '✓' : '✗'} / 説明文 ${c.description ? '✓' : '✗'} / OGP ${c.hasOgp ? '✓' : '✗'}`;
      if (c.title) sub = c.title.slice(0, 55) + (c.title.length > 55 ? '…' : '');
    }
    if (key === 'structuredData' && c.schemasFound > 0) {
      const types = [...new Set((c.schemas ?? []).map((s: any) => s.type))].slice(0, 4).join(', ');
      detail = `${c.schemasFound}件の構造化データを検出`;
      sub = types;
    }
    if (key === 'topicCluster') {
      if (c.h1Count > 0 || c.h2Count > 0) {
        detail = `H1×${c.h1Count} H2×${c.h2Count} H3×${c.h3Count} / 内部リンク ${c.internalLinks}件`;
        if (c.h1Text) sub = `"${c.h1Text.slice(0, 55)}${c.h1Text.length > 55 ? '…' : ''}"`;
      }
    }

    const li = document.createElement('li');
    li.style.cssText = 'padding:8px 0 9px;border-bottom:1px solid rgba(0,0,0,0.05);list-style:none;';
    li.innerHTML = `
      <div style="display:flex;align-items:baseline;gap:6px;">
        <span style="font-size:13px;color:${dotColor};flex-shrink:0;width:18px;line-height:1;">${sym}</span>
        <span style="font-family:monospace;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:rgba(0,0,0,0.55);flex:1;">${CHECK_LABELS[key] ?? key}</span>
        <span style="font-family:monospace;font-size:11px;"><span style="color:${scoreColor};">${score}</span><span style="color:rgba(0,0,0,0.25);">/${max}</span></span>
      </div>
      <div style="font-family:monospace;font-size:12px;color:rgba(0,0,0,0.68);padding-left:24px;line-height:1.6;margin-top:3px;">${detail}</div>
      ${sub ? `<div style="font-family:monospace;font-size:11px;color:rgba(0,0,0,0.45);padding-left:24px;margin-top:2px;line-height:1.5;">${sub}</div>` : ''}
    `;
    checksEl.appendChild(li);
  }

  async function run() {
    const url = urlInput.value.trim();
    if (!url) { urlInput.focus(); return; }

    runBtn.disabled = true;
    statusEl.classList.remove('hidden');
    errorEl.classList.add('hidden');
    resultEl.classList.add('hidden');
    checksEl.innerHTML = '';
    emailTrig.classList.remove('hidden');
    emailSec.classList.add('hidden');
    emailStat.classList.add('hidden');

    try {
      const res  = await fetch('/api/diagnose-llmo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      });
      const data = await res.json() as any;
      if (!res.ok || data.error) throw new Error(data.error ?? '診断に失敗しました');

      lastUrl    = url;
      lastResult = data;

      const { score, grade, domain, checks } = data;
      scoreEl.textContent = String(score);
      gradeEl.textContent = grade;
      gradeEl.style.color = score >= 80 ? '#1a7a1a' : score >= 60 ? '#7a6a00' : score >= 40 ? '#c05000' : '#c01010';
      gradeDescEl.textContent = GRADE_DESCS[grade] ?? '';
      domainEl.textContent = domain;

      const order = ['llmsTxt', 'robotsTxt', 'sitemapXml', 'structuredData', 'metaTags', 'topicCluster'];
      for (const key of order) if (checks[key] != null) renderCheck(key, checks[key]);

      resultEl.classList.remove('hidden');
      resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } catch (e: any) {
      errorEl.textContent = e.message ?? 'エラーが発生しました';
      errorEl.classList.remove('hidden');
    } finally {
      statusEl.classList.add('hidden');
      runBtn.disabled = false;
    }
  }

  // ── Email flow ───────────────────────────────────────────────
  emailOpen.addEventListener('click', () => {
    emailTrig.classList.add('hidden');
    emailSec.classList.remove('hidden');
    emailInput.focus();
  });

  async function sendEmail() {
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      emailStat.textContent = 'メールアドレスを確認してください。';
      emailStat.classList.remove('hidden');
      return;
    }
    emailInput.disabled = true;
    emailStat.textContent = '送信中...';
    emailStat.classList.remove('hidden');

    try {
      // Re-run diagnosis with email to trigger save+send on server
      const res = await fetch('/api/diagnose-llmo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: lastUrl, email }),
      });
      emailStat.textContent = res.ok ? '送信しました。' : '送信に失敗しました。';
      if (!res.ok) emailInput.disabled = false;
    } catch {
      emailStat.textContent = '送信に失敗しました。';
      emailInput.disabled = false;
    }
  }

  emailSend.addEventListener('click', sendEmail);
  emailInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); sendEmail(); }
  });

  runBtn.addEventListener('click', run);
  urlInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });
</script>
