---
---
<div id="hero-diagnosis" class="border-t border-black/10 pt-4 lg:pt-5">

  <!-- Label -->
  <span class="font-mono text-[11px] tracking-[0.22em] text-black/60 uppercase">LLMO 簡易診断</span>
  <p class="mt-0.5 font-mono text-[10px] text-black/28 leading-relaxed">
    robots.txt・llms.txt・構造化データのAI対応状況を無料診断 <span class="text-black/20">/ ページ単位</span>
  </p>

  <!-- URL Input row -->
  <div class="mt-3 flex gap-0">
    <input
      id="dw-url"
      type="url"
      placeholder="https://example.com/page"
      class="flex-1 min-w-0 border border-black/15 border-r-0 bg-transparent px-3 py-2 font-mono text-xs text-black outline-none placeholder:text-black/20 focus:border-black/40 transition-colors"
    />
    <button
      id="dw-run"
      class="bg-black px-4 py-2 font-mono text-[10px] tracking-[0.14em] text-white uppercase hover:bg-black/75 transition-colors whitespace-nowrap disabled:opacity-40"
    >
      診断
    </button>
  </div>

  <!-- Status / Error -->
  <p id="dw-status" class="hidden mt-2 font-mono text-[10px] text-black/35 animate-pulse">診断中...</p>
  <p id="dw-error"  class="hidden mt-2 font-mono text-[10px] text-red-600/70"></p>

  <!-- Results -->
  <div id="dw-result" class="hidden mt-4">

    <!-- Score -->
    <div class="flex items-baseline gap-2 pb-3 border-b border-black/8">
      <span id="dw-score" class="font-clash text-5xl leading-none">—</span>
      <span class="font-mono text-[10px] text-black/30">/100</span>
      <span id="dw-grade" class="font-mono text-sm font-bold ml-1"></span>
      <span id="dw-domain" class="font-mono text-[9px] text-black/30 ml-auto truncate max-w-[140px]"></span>
    </div>

    <!-- Check rows -->
    <ul id="dw-checks" class="mt-3 space-y-1.5"></ul>

    <!-- Email: send results -->
    <div class="mt-5 pt-4 border-t border-black/8">
      <div id="dw-email-trigger">
        <button id="dw-email-open" class="font-mono text-[10px] tracking-[0.12em] text-black/40 uppercase hover:text-black transition-colors">
          診断結果を受け取る →
        </button>
      </div>
      <div id="dw-email-section" class="hidden">
        <div class="flex items-center gap-2 border-b border-black/15 pb-2">
          <input
            id="dw-email-input"
            type="email"
            placeholder="メールアドレスを入力..."
            class="flex-1 bg-transparent font-mono text-xs text-black outline-none placeholder:text-black/25"
          />
          <button id="dw-email-send" class="font-mono text-xs text-black/40 transition-colors hover:text-black">→</button>
        </div>
        <p id="dw-email-status" class="hidden mt-1.5 font-mono text-[10px] text-black/40"></p>
      </div>
    </div>

    <!-- Full report CTA -->
    <div class="mt-3">
      <a
        href="/contact"
        class="font-mono text-[10px] tracking-[0.12em] text-black/30 uppercase hover:text-black transition-colors"
      >
        詳細レポートを依頼する →
      </a>
    </div>
  </div>
</div>

<script>
  const urlInput    = document.getElementById('dw-url')         as HTMLInputElement;
  const runBtn      = document.getElementById('dw-run')         as HTMLButtonElement;
  const statusEl    = document.getElementById('dw-status')!;
  const errorEl     = document.getElementById('dw-error')!;
  const resultEl    = document.getElementById('dw-result')!;
  const scoreEl     = document.getElementById('dw-score')!;
  const gradeEl     = document.getElementById('dw-grade')!;
  const domainEl    = document.getElementById('dw-domain')!;
  const checksEl    = document.getElementById('dw-checks')!;
  const emailTrig   = document.getElementById('dw-email-trigger')!;
  const emailOpen   = document.getElementById('dw-email-open')!;
  const emailSec    = document.getElementById('dw-email-section')!;
  const emailInput  = document.getElementById('dw-email-input') as HTMLInputElement;
  const emailSend   = document.getElementById('dw-email-send')!;
  const emailStat   = document.getElementById('dw-email-status')!;

  const CHECK_LABELS: Record<string, string> = {
    llmsTxt:        'llms.txt',
    robotsTxt:      'robots.txt',
    sitemapXml:     'sitemap.xml',
    metaTags:       'メタタグ',
    structuredData: '構造化データ',
  };

  let lastUrl = '';
  let lastResult: any = null;

  function checkItem(label: string, message: string, ok: boolean | null) {
    const li = document.createElement('li');
    li.style.cssText = 'display:flex;align-items:baseline;gap:0.4rem;font-family:monospace;font-size:10px;line-height:1.6;';
    const dot   = ok === null ? '·' : ok ? '✓' : '✗';
    const color = ok === null ? 'rgba(0,0,0,0.35)' : ok ? 'rgba(0,0,0,0.75)' : 'rgba(180,40,40,0.8)';
    li.innerHTML = `
      <span style="color:${color};flex-shrink:0;width:1em;">${dot}</span>
      <span style="color:rgba(0,0,0,0.32);flex-shrink:0;letter-spacing:.1em;text-transform:uppercase;">${label}</span>
      <span style="color:rgba(0,0,0,0.5);">${message}</span>
    `;
    checksEl.appendChild(li);
  }

  async function run() {
    const url = urlInput.value.trim();
    if (!url) { urlInput.focus(); return; }

    runBtn.disabled = true;
    statusEl.classList.remove('hidden');
    errorEl.classList.add('hidden');
    resultEl.classList.add('hidden');
    checksEl.innerHTML = '';
    emailTrig.classList.remove('hidden');
    emailSec.classList.add('hidden');
    emailStat.classList.add('hidden');

    try {
      const res  = await fetch('/api/diagnose-llmo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      });
      const data = await res.json() as any;
      if (!res.ok || data.error) throw new Error(data.error ?? '診断に失敗しました');

      lastUrl    = url;
      lastResult = data;

      const { score, grade, domain, checks } = data;
      scoreEl.textContent = String(score);
      gradeEl.textContent = grade;
      domainEl.textContent = domain;
      gradeEl.style.color = score >= 80 ? '#1a7a1a' : score >= 60 ? '#7a6a00' : score >= 40 ? '#c05000' : '#c01010';

      const order = ['llmsTxt', 'robotsTxt', 'sitemapXml', 'structuredData', 'metaTags'];
      for (const key of order) {
        const c = checks[key];
        const ok = 'exists' in c ? c.exists : (c.schemasFound ?? c.score) > 0;
        checkItem(CHECK_LABELS[key] ?? key, c.message, ok);
      }

      resultEl.classList.remove('hidden');
      resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } catch (e: any) {
      errorEl.textContent = e.message ?? 'エラーが発生しました';
      errorEl.classList.remove('hidden');
    } finally {
      statusEl.classList.add('hidden');
      runBtn.disabled = false;
    }
  }

  // ── Email flow ───────────────────────────────────────────────
  emailOpen.addEventListener('click', () => {
    emailTrig.classList.add('hidden');
    emailSec.classList.remove('hidden');
    emailInput.focus();
  });

  async function sendEmail() {
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      emailStat.textContent = 'メールアドレスを確認してください。';
      emailStat.classList.remove('hidden');
      return;
    }
    emailInput.disabled = true;
    emailStat.textContent = '送信中...';
    emailStat.classList.remove('hidden');

    try {
      // Re-run diagnosis with email to trigger save+send on server
      const res = await fetch('/api/diagnose-llmo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: lastUrl, email }),
      });
      emailStat.textContent = res.ok ? '送信しました。' : '送信に失敗しました。';
      if (!res.ok) emailInput.disabled = false;
    } catch {
      emailStat.textContent = '送信に失敗しました。';
      emailInput.disabled = false;
    }
  }

  emailSend.addEventListener('click', sendEmail);
  emailInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); sendEmail(); }
  });

  runBtn.addEventListener('click', run);
  urlInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });
</script>
