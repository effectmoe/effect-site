---
import MarqueeText from '@/components/common/MarqueeText.astro';
import Button from '@/components/ui/Button.astro';
import AiChatWidget from './AiChatWidget.astro';
import { t } from '@/lib/utils';
---

<div id="hero-outer" class="relative flex min-h-dvh w-full flex-col overflow-hidden lg:h-dvh lg:flex-row">

  <!-- Left Side: Info -->
  <div
    id="hero-left"
    class="bg-background relative z-10 order-2 flex w-full flex-col px-4 pb-6 pt-5 lg:order-1 lg:h-full lg:w-1/2 lg:justify-between lg:px-14 lg:pt-16 lg:pb-14"
  >
    <!-- Mobile close row (hidden until chat active) -->
    <div id="hero-chat-close-row" class="mb-4 items-center justify-between border-b border-black/10 pb-3" style="display:none;">
      <a href="/" class="font-clash text-xl leading-none text-black/80 transition-opacity hover:opacity-50">EFFECT</a>
      <button id="hero-chat-close-btn" class="font-mono text-[10px] tracking-[0.18em] text-black/35 uppercase transition-colors hover:text-black">
        × 閉じる
      </button>
    </div>

    <!-- AI Chat -->
    <div id="chat-wrapper" class="lg:flex-1 lg:overflow-hidden">
      <AiChatWidget />
    </div>

    <!-- Hero text -->
    <div id="hero-text-section" class="mt-4 flex max-w-5xl flex-col gap-4 lg:mt-0 lg:shrink-0 lg:gap-6">
      <div id="hero-marquee-split" class="hidden xl:block" style="visibility: hidden;">
        <MarqueeText text={t('index.hero.marqueetext')} />
      </div>
      <h1
        id="hero-h1-split"
        class="font-clash text-[clamp(2rem,8vw,3rem)] leading-[0.93] lg:text-[clamp(3rem,5.5vw,6rem)]"
        style="visibility: hidden;"
      >
        {t('index.hero.h1')}
      </h1>
      <div class="flex flex-col gap-3 lg:gap-4">
        <p
          id="hero-description-split"
          class="max-w-xl text-sm leading-relaxed lg:text-[clamp(0.85rem,1.5vw,1.25rem)]"
          style="visibility: hidden;"
        >
          {t('index.hero.description')}
        </p>
        <div id="hero-btn-split" class="mt-2 w-full md:mt-4" style="visibility: hidden;">
          <Button variant="primary" href="/contact">{t('index.hero.btn')}</Button>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Side: Globe -->
  <div class="relative order-1 h-[56vw] min-h-[280px] w-full lg:order-2 lg:h-full lg:min-h-0 lg:w-1/2" id="globe-container">
    <canvas
      id="globe-canvas-split"
      class="absolute inset-0 block size-full will-change-transform"
      style="visibility: hidden; opacity: 0;"></canvas>
    <div
      id="hero-coords-split"
      class="absolute right-[3vw] bottom-[5vh] z-10 font-mono text-xs leading-[1.9] tracking-[0.14em] max-md:hidden"
      style="visibility: hidden;"
    >
      <span id="globe-lon-split">LON 000.0°</span><br />
      <span>LAT 23.5° N</span>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { GlobeRenderer } from './globe.ts';

  // ── Globe animation ─────────────────────────────────────────
  const canvas = document.getElementById('globe-canvas-split') as HTMLCanvasElement;
  const lonEl  = document.getElementById('globe-lon-split') as HTMLElement;

  if (canvas && lonEl) {
    const renderer = new GlobeRenderer(canvas, {}, (deg: number) => {
      lonEl.textContent = `LON ${String(deg.toFixed(1)).padStart(5, '0')}°`;
    });

    const marquee     = document.getElementById('hero-marquee-split');
    const h1          = document.getElementById('hero-h1-split');
    const description = document.getElementById('hero-description-split');
    const btn         = document.getElementById('hero-btn-split');
    const coords      = document.getElementById('hero-coords-split');

    gsap.set([marquee, h1, description, btn], { y: 28, opacity: 0 });
    gsap.set(coords, { opacity: 0 });
    gsap.set(canvas, { opacity: 0, scale: 1.04 });
    gsap.set([canvas, marquee, h1, description, btn, coords], { visibility: 'visible' });

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.to(canvas, { opacity: 1, scale: 1, duration: 1.4, ease: 'power2.out' })
      .to(marquee,      { y: 0, opacity: 1, duration: 0.7 }, '-=0.8')
      .to(h1,           { y: 0, opacity: 1, duration: 0.85, ease: 'power4.out' }, '-=0.55')
      .to(description,  { y: 0, opacity: 1, duration: 0.7 }, '-=0.5')
      .to(btn,          { y: 0, opacity: 1, duration: 0.6 }, '-=0.45')
      .to(coords,       { opacity: 1, duration: 0.8 }, '-=0.6');

    const observer = new IntersectionObserver(
      (entries) => entries.forEach((e) => e.isIntersecting ? renderer.resume() : renderer.pause()),
      { threshold: 0 },
    );
    const globeContainer = document.getElementById('globe-container');
    if (globeContainer) observer.observe(globeContainer);

    document.addEventListener('astro:before-swap', () => {
      observer.disconnect();
      renderer.destroy();
    }, { once: true });
  }

  // ── Mobile chat expansion (pure inline styles — avoids Astro CSS scoping) ──
  const heroOuter    = document.getElementById('hero-outer')!;
  const heroLeft     = document.getElementById('hero-left')!;
  const heroText     = document.getElementById('hero-text-section')!;
  const globeEl      = document.getElementById('globe-container')!;
  const closeRow     = document.getElementById('hero-chat-close-row')!;
  const closeBtn     = document.getElementById('hero-chat-close-btn')!;

  // Store original inline styles for restoration
  const orig = {
    outerPosition:   heroOuter.style.position,
    outerInset:      heroOuter.style.inset,
    outerZIndex:     heroOuter.style.zIndex,
    outerOverflow:   heroOuter.style.overflow,
    leftHeight:      heroLeft.style.height,
    leftPaddingTop:  heroLeft.style.paddingTop,
    leftOverflow:    heroLeft.style.overflow,
    leftDisplay:     heroLeft.style.display,
    leftFlexDir:     heroLeft.style.flexDirection,
  };

  function expandChat() {
    if (window.innerWidth >= 1024) return;

    // Full-screen overlay
    Object.assign(heroOuter.style, { position: 'fixed', inset: '0', zIndex: '50', overflow: 'hidden' });

    // Hide globe and hero text
    globeEl.style.display  = 'none';
    heroText.style.display = 'none';

    // Left panel fills viewport
    Object.assign(heroLeft.style, {
      height: '100dvh', paddingTop: '2.75rem',
      overflow: 'hidden', display: 'flex', flexDirection: 'column',
    });

    // Show close row
    closeRow.style.display = 'flex';

    // Expand chat wrapper and widget to fill panel
    const chatWrapper = document.getElementById('chat-wrapper');
    const aiChat      = document.getElementById('ai-chat');
    const aiMessages  = document.getElementById('ai-messages');
    if (chatWrapper) Object.assign(chatWrapper.style, { flex: '1', overflow: 'hidden', display: 'flex', flexDirection: 'column' });
    if (aiChat) Object.assign(aiChat.style, { flex: '1', display: 'flex', flexDirection: 'column', overflowY: 'auto' });
    if (aiMessages) Object.assign(aiMessages.style, { flex: '1', maxHeight: 'none' });
  }

  function collapseChat() {
    // Restore outer
    Object.assign(heroOuter.style, {
      position: orig.outerPosition, inset: orig.outerInset,
      zIndex: orig.outerZIndex, overflow: orig.outerOverflow,
    });

    // Restore visibility
    globeEl.style.display  = '';
    heroText.style.display = '';
    closeRow.style.display = 'none';

    // Restore left panel
    Object.assign(heroLeft.style, {
      height: orig.leftHeight, paddingTop: orig.leftPaddingTop,
      overflow: orig.leftOverflow, display: orig.leftDisplay, flexDirection: orig.leftFlexDir,
    });

    // Restore chat widget
    const chatWrapper = document.getElementById('chat-wrapper');
    const aiChat      = document.getElementById('ai-chat');
    const aiMessages  = document.getElementById('ai-messages');
    if (chatWrapper) Object.assign(chatWrapper.style, { flex: '', overflow: '', display: '', flexDirection: '' });
    if (aiChat) Object.assign(aiChat.style, { flex: '', display: '', flexDirection: '', overflowY: '' });
    if (aiMessages) Object.assign(aiMessages.style, { flex: '', maxHeight: '' });
  }

  document.addEventListener('chat:started', expandChat);
  closeBtn.addEventListener('click', collapseChat);
  // ────────────────────────────────────────────────────────────
</script>
