---
import type { CollectionEntry } from 'astro:content';
import { t } from '@/lib/utils';
import MarqueeText from '@/components/common/MarqueeText.astro';
import BlogCard from './BlogCard.astro';

interface Props {
  blogs: CollectionEntry<'blogs'>[];
}

const { blogs } = Astro.props;
---

<section data-blog="section" class="container mx-auto space-y-6 px-4 pt-24 pb-20 md:space-y-12 lg:pt-36 lg:pb-28">
  <div class="max-w-5xl space-y-3 md:space-y-5">
    <div data-blog="cta">
      <MarqueeText text={t('blog.marqueetext')} />
    </div>
    <h1 data-blog="heading" class="font-clash text-4xl md:text-7xl lg:text-8xl">
      {t('blog.title')}
    </h1>
    <p data-blog="desc" class="font-grotesk max-w-3xl text-lg leading-relaxed md:text-2xl">
      {t('blog.description')}
    </p>
  </div>
  <div data-blog="projects" class="grid grid-cols-1 gap-6 md:grid-cols-2">
    {blogs.map((blog) => <BlogCard blog={blog} />)}
  </div>
</section>

<style>
  [data-blog='section'] [data-blog='cta'],
  [data-blog='section'] [data-blog='heading'],
  [data-blog='section'] [data-blog='desc'],
  [data-blog='section'] [data-blog='projects'] {
    visibility: hidden;
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('[data-blog="section"]');
  if (section) {
    const q = (attr: string) => section.querySelector(`[data-blog="${attr}"]`);

    gsap.set([q('cta'), q('heading'), q('desc'), q('projects')], { opacity: 0, y: 20 });

    gsap
      .timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          once: true,
        },
      })
      .to(q('cta'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.5, ease: 'power2.out' })
      .to(q('heading'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.7, ease: 'power3.out' }, '-=0.3')
      .to(q('desc'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .to(q('projects'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.7, ease: 'power3.out' }, '-=0.3');
  }
</script>
