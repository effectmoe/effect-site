---
interface Props {
  articleId: string;
  articleTitle: string;
  articleBody: string;
}

const { articleId, articleTitle, articleBody } = Astro.props;

const truncatedBody = articleBody.slice(0, 3000);
const suggestions = [
  'この記事の要点を教えて',
  'もう少し詳しく説明して',
  '実際にどう使えばいい？',
];
---

<div id="concierge-root" class="border border-foreground/20">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-foreground/20 bg-foreground px-5 py-4">
      <div class="flex items-center gap-3">
        <span class="font-mono text-[11px] tracking-[0.22em] text-background/70 uppercase">AI Concierge</span>
        <span id="concierge-status" class="inline-block h-1.5 w-1.5 rounded-full bg-background/30"></span>
      </div>
      <span class="font-mono text-[10px] tracking-widest text-background/40 uppercase">この記事専用</span>
    </div>

    <!-- Body -->
    <div class="bg-primary-foreground px-5 py-5">
      <!-- Intro (hidden after first message) -->
      <div id="concierge-intro" class="mb-4 space-y-1">
        <p class="font-mono text-xs leading-relaxed text-foreground/60">
          記事「<span class="text-foreground/85">{articleTitle}</span>」に関するご質問にお答えします。
        </p>
        <p class="font-mono text-[10px] tracking-widest text-foreground/35 uppercase">
          記事以外のトピックには回答できません
        </p>
      </div>

      <!-- Messages -->
      <div
        id="concierge-messages"
        class="mb-4 max-h-64 space-y-4 overflow-y-auto pr-1"
        style="scrollbar-width: none;"
      ></div>

      <!-- Suggestion chips -->
      <div id="concierge-suggestions" class="mb-4 flex flex-wrap gap-2">
        {suggestions.map((s) => (
          <button
            class="concierge-suggestion border border-foreground/20 bg-transparent px-3 py-1.5 font-mono text-[11px] tracking-wide text-foreground/50 transition-colors hover:border-foreground/50 hover:text-foreground/80"
          >
            {s}
          </button>
        ))}
      </div>

      <!-- Input -->
      <div class="flex items-center gap-3 border-b border-foreground/20 pb-2">
        <input
          id="concierge-input"
          type="text"
          placeholder="この記事について質問する..."
          maxlength="300"
          class="flex-1 bg-transparent font-mono text-xs text-foreground outline-none placeholder:text-foreground/25"
        />
        <button
          id="concierge-send"
          aria-label="送信"
          class="font-mono text-xs text-foreground/30 transition-colors hover:text-foreground"
        >→</button>
      </div>

      <!-- Email log trigger（初回レスポンス後に表示） -->
      <div id="concierge-email-trigger" class="mt-4 hidden">
        <div class="flex flex-wrap items-center gap-4">
          <button id="concierge-email-open"
            class="inline-flex items-center gap-1.5 border border-foreground/20 px-3 py-1.5 font-mono text-[10px] tracking-widest text-foreground/55 uppercase transition-all hover:border-foreground/40 hover:text-foreground/80">
            ログをメールで受け取る <span class="text-foreground/30">→</span>
          </button>
        </div>
      </div>

      <!-- Email input section -->
      <div id="concierge-email-section" class="mt-3 hidden">
        <div class="flex items-center gap-2 border-b border-foreground/20 pb-2">
          <input
            id="concierge-email-input"
            type="email"
            placeholder="メールアドレスを入力..."
            class="flex-1 bg-transparent font-mono text-xs text-foreground outline-none placeholder:text-foreground/30"
          />
          <button id="concierge-email-send" class="font-mono text-xs text-foreground/40 transition-colors hover:text-foreground">→</button>
        </div>
        <p id="concierge-email-status" class="mt-1.5 hidden font-mono text-[10px] text-foreground/40"></p>
      </div>

      <!-- Sandbox note -->
      <p class="mt-3 font-mono text-[10px] tracking-widest text-foreground/25 uppercase">
        Powered by Cloudflare AI · Sandboxed to this article
      </p>
    </div>
</div>

<style>
  #concierge-messages::-webkit-scrollbar { display: none; }

  .concierge-msg[data-role="user"] {
    display: flex;
    justify-content: flex-end;
  }
  .concierge-msg[data-role="user"] .msg-bubble {
    color: rgba(0,0,0,0.82);
    text-align: right;
    background: rgba(0,0,0,0.05);
    padding: 0.5rem 0.75rem;
    max-width: 80%;
    font-family: var(--font-roboto-mono), monospace;
    font-size: 0.75rem;
    line-height: 1.8;
  }
  .concierge-msg[data-role="assistant"] .msg-bubble {
    color: rgba(0,0,0,0.75);
    font-size: 0.8125rem;
    line-height: 1.75;
  }

  /* Rich text inside assistant messages */
  .concierge-msg[data-role="assistant"] .msg-bubble p { margin: 0.5em 0; }
  .concierge-msg[data-role="assistant"] .msg-bubble p:first-child { margin-top: 0; }
  .concierge-msg[data-role="assistant"] .msg-bubble p:last-child { margin-bottom: 0; }
  .concierge-msg[data-role="assistant"] .msg-bubble strong { font-weight: 700; color: rgba(0,0,0,0.88); }
  .concierge-msg[data-role="assistant"] .msg-bubble em { font-style: italic; }
  .concierge-msg[data-role="assistant"] .msg-bubble h2,
  .concierge-msg[data-role="assistant"] .msg-bubble h3,
  .concierge-msg[data-role="assistant"] .msg-bubble h4 {
    font-weight: 700;
    margin: 0.75em 0 0.25em;
    color: rgba(0,0,0,0.88);
    line-height: 1.4;
  }
  .concierge-msg[data-role="assistant"] .msg-bubble h2 { font-size: 1em; }
  .concierge-msg[data-role="assistant"] .msg-bubble h3 { font-size: 0.9375em; }
  .concierge-msg[data-role="assistant"] .msg-bubble h4 { font-size: 0.875em; }
  .concierge-msg[data-role="assistant"] .msg-bubble ul,
  .concierge-msg[data-role="assistant"] .msg-bubble ol {
    padding-left: 1.25em;
    margin: 0.4em 0;
  }
  .concierge-msg[data-role="assistant"] .msg-bubble li { margin: 0.2em 0; }
  .concierge-msg[data-role="assistant"] .msg-bubble code {
    font-family: var(--font-roboto-mono), monospace;
    font-size: 0.85em;
    background: rgba(0,0,0,0.07);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }
  .concierge-msg[data-role="assistant"] .msg-bubble pre {
    background: rgba(0,0,0,0.06);
    padding: 0.75em 1em;
    overflow-x: auto;
    margin: 0.5em 0;
    border-radius: 2px;
  }
  .concierge-msg[data-role="assistant"] .msg-bubble pre code {
    background: none;
    padding: 0;
    font-size: 0.8125em;
  }

  .typing::after {
    content: '▋';
    animation: blink 0.8s step-end infinite;
    opacity: 0.4;
  }
  @keyframes blink { 0%,100%{opacity:0.4} 50%{opacity:0} }
</style>

<script define:vars={{ articleId, articleTitle, truncatedBody }}>
  const messagesEl      = document.getElementById('concierge-messages');
  const inputEl         = document.getElementById('concierge-input');
  const sendBtn         = document.getElementById('concierge-send');
  const statusDot       = document.getElementById('concierge-status');
  const introEl         = document.getElementById('concierge-intro');
  const suggestEl       = document.getElementById('concierge-suggestions');
  const emailTrigger    = document.getElementById('concierge-email-trigger');
  const emailOpenBtn    = document.getElementById('concierge-email-open');
  const emailSection    = document.getElementById('concierge-email-section');
  const emailInput      = document.getElementById('concierge-email-input');
  const emailSendBtn    = document.getElementById('concierge-email-send');
  const emailStatus     = document.getElementById('concierge-email-status');

  const history = [];
  let chatStarted = false;
  let firstResponseReceived = false;

  const articleContext = { id: articleId, title: articleTitle, body: truncatedBody };

  // ── Markdown → HTML（XSSセーフ）────────────────────────────
  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function parseMarkdown(raw) {
    let s = esc(raw);
    // コードブロック（インライン変換より先に処理）
    s = s.replace(/```[\w]*\n?([\s\S]*?)```/g, (_,c) => `<pre><code>${c.trimEnd()}</code></pre>`);
    // インラインコード
    s = s.replace(/`([^`\n]+)`/g, '<code>$1</code>');
    // 見出し
    s = s.replace(/^### (.+)$/gm, '<h4>$1</h4>');
    s = s.replace(/^## (.+)$/gm,  '<h3>$1</h3>');
    s = s.replace(/^# (.+)$/gm,   '<h2>$1</h2>');
    // 太字・斜体
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>');
    s = s.replace(/\*(.+?)\*/g,         '<em>$1</em>');
    // 箇条書き（連続する li をまとめて ul/ol に包む）
    s = s.replace(/^[-*] (.+)$/gm,    '<li>$1</li>');
    s = s.replace(/^\d+\. (.+)$/gm,   '<li>$1</li>');
    s = s.replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`);
    // 段落（ブロック要素を分離してから <p> で包む）
    const blocks = s.split(/\n{2,}/);
    s = blocks.map(b => {
      b = b.trim();
      if (!b) return '';
      if (/^<(h[234]|ul|ol|pre|li)/.test(b)) return b;
      return `<p>${b.replace(/\n/g, '<br>')}</p>`;
    }).join('');
    return s;
  }
  // ──────────────────────────────────────────────────────────

  function addMsg(role, text = '') {
    const div = document.createElement('div');
    div.className = 'concierge-msg';
    div.dataset.role = role;

    if (role === 'user') {
      const label = document.createElement('span');
      label.className = 'mb-0.5 block font-mono text-[10px] tracking-widest text-foreground/25 uppercase text-right';
      label.textContent = 'YOU';
      div.appendChild(label);
    }

    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';
    if (role === 'user') bubble.textContent = text;
    div.appendChild(bubble);
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return bubble;
  }

  function setLoading(loading) {
    statusDot.style.backgroundColor = loading ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.3)';
    inputEl.disabled = loading;
    sendBtn.toggleAttribute('disabled', loading);
  }

  async function send(text) {
    if (!text.trim() || inputEl.disabled) return;

    if (!chatStarted) {
      chatStarted = true;
      introEl.style.display = 'none';
      suggestEl.style.display = 'none';
    }

    addMsg('user', text);
    history.push({ role: 'user', content: text });
    inputEl.value = '';
    setLoading(true);

    const bubble = addMsg('assistant');
    bubble.classList.add('typing');

    try {
      const res = await fetch('/api/article-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history: history.slice(-6), articleContext }),
      });
      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

      const reader = res.body.getReader();
      const dec = new TextDecoder();
      let full = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        for (const line of dec.decode(value, { stream: true }).split('\n')) {
          if (!line.startsWith('data: ')) continue;
          const raw = line.slice(6).trim();
          if (raw === '[DONE]') break;
          try {
            const d = JSON.parse(raw);
            const token = d.response ?? d.choices?.[0]?.delta?.content ?? '';
            full += token;
            // ストリーム中はプレーンテキスト表示
            bubble.textContent = full;
            messagesEl.scrollTop = messagesEl.scrollHeight;
          } catch {}
        }
      }

      // 受信完了後にMarkdownとしてレンダリング
      bubble.classList.remove('typing');
      bubble.innerHTML = parseMarkdown(full);
      history.push({ role: 'assistant', content: full });

      if (!firstResponseReceived && full) {
        firstResponseReceived = true;
        emailTrigger.classList.remove('hidden');
      }
    } catch {
      bubble.classList.remove('typing');
      bubble.textContent = '接続エラーが発生しました。しばらくしてから再試行してください。';
    } finally {
      setLoading(false);
      inputEl.focus();
    }
  }

  // ── メールログ送信 ────────────────────────────────────────
  emailOpenBtn.addEventListener('click', () => {
    emailTrigger.classList.add('hidden');
    emailSection.classList.remove('hidden');
    emailInput.focus();
  });

  async function sendEmailLog() {
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      emailStatus.textContent = 'メールアドレスを確認してください。';
      emailStatus.classList.remove('hidden');
      return;
    }
    emailInput.disabled = true;
    emailStatus.textContent = '送信中...';
    emailStatus.classList.remove('hidden');

    try {
      const res = await fetch('/api/save-conversation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history, email, articleTitle }),
      });
      emailStatus.textContent = res.ok ? '送信しました。' : '送信に失敗しました。';
      if (!res.ok) emailInput.disabled = false;
    } catch {
      emailStatus.textContent = '送信に失敗しました。';
      emailInput.disabled = false;
    }
  }

  emailSendBtn.addEventListener('click', sendEmailLog);
  emailInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); sendEmailLog(); }
  });
  // ──────────────────────────────────────────────────────────

  sendBtn.addEventListener('click', () => send(inputEl.value));

  let isComposing = false;
  inputEl.addEventListener('compositionstart', () => { isComposing = true; });
  inputEl.addEventListener('compositionend', () => { isComposing = false; });
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !isComposing) { e.preventDefault(); send(inputEl.value); }
  });

  document.querySelectorAll('.concierge-suggestion').forEach((btn) => {
    btn.addEventListener('click', () => send(btn.textContent.trim()));
  });
</script>
