---
import MarqueeText from '@/components/common/MarqueeText.astro';
import WorksCard from './WorksCard.astro';
import { t } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section data-works="section" class="container mx-auto space-y-6 px-4 pt-24 pb-20 md:space-y-12 lg:pt-36 lg:pb-28">
  <div class="max-w-5xl space-y-3 md:space-y-5">
    <div data-works="cta">
      <MarqueeText text={t('works.marqueetext')} />
    </div>
    <h1 data-works="heading" class="font-clash text-4xl md:text-7xl lg:text-8xl">
      {t('works.title')}
    </h1>
    <p data-works="desc" class="max-w-3xl text-lg leading-relaxed md:text-2xl">
      {t('works.description')}
    </p>
  </div>
  <div data-works="projects" class="grid grid-cols-1 gap-6 md:grid-cols-2">
    {projects.map((project) => <WorksCard project={project} />)}
  </div>
</section>

<style>
  [data-works='section'] [data-works='cta'],
  [data-works='section'] [data-works='heading'],
  [data-works='section'] [data-works='desc'],
  [data-works='section'] [data-works='projects'] {
    visibility: hidden;
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('[data-works="section"]');
  if (section) {
    const q = (attr: string) => section.querySelector(`[data-works="${attr}"]`);

    gsap.set([q('cta'), q('heading'), q('desc'), q('projects')], { opacity: 0, y: 20 });

    gsap
      .timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          once: true,
        },
      })
      .to(q('cta'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.5, ease: 'power2.out' })
      .to(q('heading'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.7, ease: 'power3.out' }, '-=0.3')
      .to(q('desc'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .to(q('projects'), { opacity: 1, y: 0, visibility: 'visible', duration: 0.7, ease: 'power3.out' }, '-=0.3');
  }
</script>
