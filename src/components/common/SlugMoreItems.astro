---
import MarqueeText from '@/components/common/MarqueeText.astro';
import Button from '@/components/ui/Button.astro';

interface Props {
  marqueeText: string;
  heading: string;
  buttonLabel: string;
  buttonHref: string;
}

const { marqueeText, heading, buttonLabel, buttonHref } = Astro.props;
---

<section class="container mx-auto space-y-10 px-4 py-24 md:space-y-16 md:py-32">
  <div class="space-y-3 md:space-y-6">
    <MarqueeText text={marqueeText} />
    <div class="flex flex-col items-start justify-between space-y-3 md:flex-row md:items-center md:space-y-0">
      <h3 class="font-clash max-w-4xl text-4xl md:text-6xl lg:text-7xl">{heading}</h3>
      <Button href={buttonHref} variant="primary" class="h-fit w-fit">
        {buttonLabel}
      </Button>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <slot />
  </div>
</section>
