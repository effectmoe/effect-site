---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/Button.astro';
import { t } from '@/lib/utils';
---

<Layout title={t('meta.404.title')} description={t('meta.404.description')}>
  <section class="flex min-h-dvh items-center justify-center px-4 py-24 lg:py-32">
    <div class="mx-auto max-w-7xl space-y-6 text-center">
      <!-- Large 404 -->
      <h1 class="font-clash text-accent text-6xl leading-none md:text-7xl lg:text-[11rem]">
        {t('404.h1')}
      </h1>

      <!-- Error Message -->
      <div class="space-y-6">
        <h2 class="font-clash text-4xl leading-tight md:text-5xl lg:text-6xl">
          {t('404.h2')}
        </h2>
        <p class="font-grotesk mx-auto max-w-2xl text-lg md:text-xl">
          {t('404.description')}
        </p>
      </div>

      <!-- Navigation Options -->
      <div class="flex flex-col items-center justify-center gap-4 md:flex-row">
        <Button variant="primary" size="md" href="/" class="w-full sm:w-auto">
          {t('404.back.btn')}
        </Button>
        <Button variant="outline" size="md" href="/contact" class="w-full sm:w-auto">
          {t('404.contact.btn')}
        </Button>
      </div>
    </div>
  </section>
</Layout>
