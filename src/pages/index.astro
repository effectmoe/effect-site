---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import GlobeHeroSplit from '@/components/sections/home/hero/GlobeHeroSplit.astro';
import AboutHome from '@/components/sections/home/AboutHome.astro';
import Services from '@/components/sections/home/service/Services.astro';
import Process from '@/components/sections/home/process/Process.astro';
import WorksHome from '@/components/sections/home/works-home/WorksHome.astro';
import Testimonials from '@/components/sections/home/Testimonials.astro';
import KnowledgeHome from '@/components/sections/home/blogs-home/KnowledgeHome.astro';
import { t } from '@/lib/utils';

const KNOWLEDGE_COUNT = 4; // ← この数字を変えるとホームの表示件数が変わる

const projects = await getCollection('projects');
const projectFilter = projects.filter((project) => project.data.featured).slice(0, 3);

const knowledge = await getCollection('knowledge', ({ data }) => !data.draft);
const articles = await getCollection('articles', ({ data }) => !data.draft);
const allEntries = [
  ...knowledge.map((e) => ({
    id: e.id, href: `/knowledge/${e.id}`,
    title: e.data.title, description: e.data.description, date: e.data.date,
    category: e.data.category, tags: e.data.tags ?? [], heroImage: e.data.heroImage,
  })),
  ...articles.map((e) => ({
    id: e.id, href: `/articles/${e.id}`,
    title: e.data.title, description: e.data.description, date: e.data.date,
    category: e.data.category, tags: e.data.tags ?? [], heroImage: e.data.heroImage,
  })),
].sort((a, b) => {
  const ta = a.date instanceof Date ? a.date.getTime() : new Date(String(a.date ?? 0)).getTime();
  const tb = b.date instanceof Date ? b.date.getTime() : new Date(String(b.date ?? 0)).getTime();
  return tb - ta;
});
---

<Layout title={t('meta.index.title')} description={t('meta.index.description')} keywords={t('meta.index.keywords')}>
  <GlobeHeroSplit />
  <KnowledgeHome entries={allEntries} count={KNOWLEDGE_COUNT} />
  <AboutHome />
  <Services />
  <Process />
  <WorksHome projects={projectFilter} />
  <Testimonials />
</Layout>
