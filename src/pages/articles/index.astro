---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import ArticleListContent from '@/components/sections/article/ArticleListContent.astro';

const raw = await getCollection('articles', ({ data }) => !data.draft);
const entries = raw.map((e) => ({
  id: e.id,
  href: `/articles/${e.id}`,
  title: e.data.title,
  description: e.data.description,
  date: e.data.date,
  category: e.data.category,
  tags: e.data.tags,
  heroImage: e.data.heroImage,
}));
---

<Layout title="記事 — EFFECT" description="AIとデジタル戦略に関する記事">
  <ArticleListContent
    entries={entries}
    pageTitle="記事"
    marqueeText="Articles"
    pageDescription="デジタル戦略とAI活用に関する実践的な記事を公開しています。"
  />
</Layout>
