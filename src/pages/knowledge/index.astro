---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import ArticleListContent from '@/components/sections/article/ArticleListContent.astro';

const rawKnowledge = await getCollection('knowledge', ({ data }) => !data.draft);
const rawArticles  = await getCollection('articles',  ({ data }) => !data.draft);

const entries = [
  ...rawKnowledge.map((e) => ({
    id: e.id,
    href: `/knowledge/${e.id}`,
    title: e.data.title,
    description: e.data.description,
    date: e.data.date,
    category: e.data.category,
    tags: e.data.tags,
    heroImage: e.data.heroImage,
  })),
  ...rawArticles.map((e) => ({
    id: e.id,
    href: `/articles/${e.id}`,
    title: e.data.title,
    description: e.data.description,
    date: e.data.date,
    category: e.data.category,
    tags: e.data.tags,
    heroImage: e.data.heroImage,
  })),
].sort((a, b) => {
  const ta = a.date instanceof Date ? a.date.getTime() : new Date(String(a.date ?? 0)).getTime();
  const tb = b.date instanceof Date ? b.date.getTime() : new Date(String(b.date ?? 0)).getTime();
  return tb - ta;
});
---

<Layout title="ナレッジ — EFFECT" description="AIとLLMOに関するナレッジベース">
  <ArticleListContent
    entries={entries}
    pageTitle="ナレッジ"
    marqueeText="Knowledge Base"
    pageDescription="AIとLLMO最適化に関する構造化された知見を集積しています。"
  />
</Layout>
